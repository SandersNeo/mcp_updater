{
  "project": "orders",
  "repo": {
    "branch": "master",
    "remote": "origin",
    "pullMode": "ff-only",
    "cloneUrl": "https://gitlab.example.com/team/orders.git",
    "auth": {
      "type": "gitlab-token",
      "tokenSecret": "GITLAB_TOKEN",
      "username": "oauth2"
    }
  },
  "sources": {
    "mainConfigPath": "src/cf",
    "mainConfigRequired": true,
    "extensionPath": "src/cfe",
    "extensionRequired": false,
    "nativeReportPath": null
  },
  "mcp": {
    "image": "comol/1c_code_metadata_mcp:light",
    "indexStorageRoot": "\\\\wsl.localhost\\Ubuntu\\mcp-indexes\\orders",
    "indexContainerPath": "/app/chroma_db",
    "containerPort": 8000,
    "production": {
      "containerName": "mcp-orders",
      "hostPort": 8100,
      "url": "http://localhost:8100/mcp"
    },
    "build": {
      "containerName": "mcp-orders-build",
      "hostPort": 18100,
      "url": "http://localhost:18100/mcp"
    },
    "indexCode": true,
    "indexMetadata": true,
    "indexHelp": false,
    "resetDatabaseOnBuild": true,
    "resetCache": false,
    "useSse": false,
    "useGpu": false,
    "env": {
      "OPENAI_API_BASE": "https://openrouter.ai/api/v1",
      "OPENAI_MODEL": "qwen/qwen3-embedding-8b"
    }
  },
  "paths": {
    "root": "C:/mcp-updater-data/orders"
  },
  "notifications": {
    "enabled": true,
    "onSuccess": true,
    "onFailure": true,
    "onRollback": true,
    "webhookUrlSecret": "MCP_UPDATE_WEBHOOK_URL"
  },
  "retention": {
    "keepPreviousIndexes": 1,
    "keepLogsDays": 30,
    "keepStagingBuilds": 2
  },
  "rollback": {
    "preserveFailedIndex": true
  }
}
